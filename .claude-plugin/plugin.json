  "version": "1.4.0",
  "author": {
    "name": "Rayyan Aquino"
  },
  "homepage": "https://github.com/ray-aqno/Toto-Wolff",
  "repository": "https://github.com/ray-aqno/Toto-Wolff",
  "license": "MIT",
  "keywords": ["governance", "p10", "council", "vault", "planning", "mcp"],
  "skills": [
    "./.claude/skills/drs",
    "./.claude/skills/karpathy",
    "./.claude/skills/linear-sync",
    "./.claude/skills/safety-car",
    "./.claude/skills/strangler-pattern-guide",
    "./.claude/skills/p10",
    "./.claude/skills/llm-council",
    "./.claude/skills/the-cabinet"
