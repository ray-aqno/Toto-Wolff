{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Canonical sensitive-pattern list for toto-wolff governance. Any change here must be reflected in the CLAUDE.md ##sensitive-patterns section. Run pnpm check-patterns to verify sync.",
  "patterns": [
    "authToken",
    "auth_token",
    "authHeader",
    "isAuthenticated",
    "requireAuth",
    "Authorization:",
    "authenticate\\(",
    "service\\.boundar",
    "data\\.migrat",
    "permission",
    "has_role",
    "hasRole",
    "checkRole",
    "role\\.based",
    "role_based",
    "tenant",
    "policy",
    "rbac",
    "acl",
    "iam",
    "secret",
    "credentialStore",
    "storeCredential",
    "credential_file",
    "credential_store",
    "X-Credential",
    "apiKey",
    "api_key",
    "API_KEY",
    "tokenStore",
    "storeToken",
    "token_store",
    "process\\.env\\.\\w*TOKEN",
    "Bearer\\s+[A-Za-z0-9._-]+",
    "\\btoken\\s*[:=]"
  ]
}
