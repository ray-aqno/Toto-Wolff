{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Canonical sensitive-pattern list for toto-wolff governance. Any change here must be reflected in the CLAUDE.md ##sensitive-patterns section. Run pnpm check-patterns to verify sync.",
  "patterns": [
    "authToken",
    "auth_token",
    "authHeader",
    "isAuthenticated",
    "requireAuth",
    "Authorization:",
    "authenticate\\(",
    "service\\.boundar",
    "data\\.migrat",
    "permission",
    "[a-zA-Z_](role|Role)",
    "(role|Role)[A-Z_]",
    "has_role",
    "hasRole",
    "checkRole",
    "role\\.based",
    "role_based",
    "tenant",
    "policy",
    "rbac",
    "acl",
    "iam",
    "secret",
    "credential",
    "api\\.key",
    "token"
  ]
}
