{
  "name": "toto-wolff",
  "version": "1.4.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint packages --max-warnings 0",
    "typecheck": "tsc -b",
    "check-patterns": "tsx --tsconfig scripts/tsconfig.json scripts/check-patterns.ts",
    "bump-version": "tsx --tsconfig scripts/tsconfig.json scripts/bump-version.ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vitest": "^3.2.6"
  }
}
