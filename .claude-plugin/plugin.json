  "mcpServers": {
    "toto-wolff": {
      "command": "npx",
      "args": [
        "--yes",
        "tsx@4.22.4",
        "--tsconfig",
        "${CLAUDE_PLUGIN_ROOT}/packages/mcp-server/tsconfig.plugin.json",
        "${CLAUDE_PLUGIN_ROOT}/packages/mcp-server/src/index.ts"
      ]
